{
  "name": "mm-jsr",
  "version": "3.0.2",
  "description": "Pure JS range input solution",
  "license": "LGPLv3",
  "author": "Mateusz Koteja <soanvig@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/soanvig/mm-jsr.git",
    "directory": "packages/mm-jsr"
  },
  "type": "module",
  "main": "./build/index.js",
  "types": "./build/index.d.ts",
  "scripts": {
    "build": "rollup --config rollup.config.js",
    "watch": "rollup --watch --config rollup.config.js",
    "docs-build": "typedoc ./src/api.ts",
    "docs-serve": "pnpm docs-build && pnpm exec serve -l 3004 api",
    "serve": "pnpm build && pnpm exec serve -l 3000 .",
    "test": "vitest",
    "size-limit": "./size-limit.bash"
  },
  "devDependencies": {
    "@rollup/plugin-terser": "1.0.0",
    "@rollup/plugin-typescript": "12.3.0",
    "@types/node": "26.0.1",
    "rollup": "4.62.2",
    "serve": "14.2.6",
    "typedoc": "0.28.19",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
